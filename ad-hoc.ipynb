    "import rawpy\n",
    "import imageio\n",
    "\n",
    "with rawpy.imread(\"input_photo/IMG_3207.CR3\") as raw:\n",
    "    mosaic = raw.raw_image.copy()   # Bayer mosaic\n",
    "\n",
    "imageio.imwrite(\"input_photo/IMG_3207.tiff\", mosaic.astype(\"uint16\"))"
   ]
  }
